# OpenRouter — required for receipt scanning
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Public URL used for OpenRouter attribution headers
PUBLIC_APP_URL=https://bill-splitter-pro.vercel.app

# Comma-separated list of origins allowed to call /api/parse-receipt.
# Leave empty in local dev (NODE_ENV=development) and the origin guard
# falls back to allowing any local origin.
ALLOWED_ORIGINS=https://bill-splitter-pro.vercel.app,http://localhost:3000

# Upstash Redis for per-IP rate limiting on /api/parse-receipt.
# If both are unset the limiter fails open with a console warning
# (acceptable in local dev, NOT in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
