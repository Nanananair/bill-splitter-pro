# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Any vision-capable model on OpenRouter. Defaults to google/gemini-2.5-flash if unset.
# Other good picks:
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o
#   google/gemini-2.5-pro
OPENROUTER_MODEL=google/gemini-2.5-flash

PORT=3001

# CORS: leave blank in dev to allow any origin; set to your deployed frontend in prod
ALLOWED_ORIGIN=

# Used for OpenRouter's HTTP-Referer attribution header
PUBLIC_APP_URL=http://localhost:8080
