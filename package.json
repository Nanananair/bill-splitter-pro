{
  "name": "bill-splitter-pro",
  "version": "0.2.0",
  "private": true,
  "description": "Smart bill splitting calculator with receipt scanning, deployed on Vercel.",
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "dev:vite": "vite",
